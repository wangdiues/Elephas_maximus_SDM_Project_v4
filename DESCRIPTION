Package: elephas.sdm
Type: Package
Title: Elephas maximus SDM Pipeline
Version: 3.0.0
Date: 2026-03-15
Authors@R: c(
    person("Elephas", "maximus SDM Team", , "team@elephas-sdm.org", role = c("aut", "cre")),
    person("Conservation Biology Research Group", role = "cph")
